<!DOCTYPE html>
<html>
<head>
    <title>Товары</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial; max-width: 1200px; margin: 30px auto; padding: 20px; background: #f5f5f5; }
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 10px; }
        .filters { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; background: white; padding: 15px; border-radius: 8px; }
        .filters input, .filters select { padding: 8px; border: 1px solid #ddd; border-radius: 4px; }
        .filters button { padding: 8px 20px; background: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; }
        .filters button:hover { background: #0056b3; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; margin-top: 20px; }
        .card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .card h3 { margin: 0 0 10px; }
        .card .price { font-size: 20px; color: #007bff; font-weight: bold; }
        .card .category { color: #666; font-size: 14px; }
        .card .rating { color: #f5a623; margin: 5px 0; }
        .count { color: #666; margin-top: 10px; }
        .reset { color: #007bff; text-decoration: none; }
    </style>
</head>
<body>
    <div class="header">
        <h1>📦 Товары</h1>
        <div class="count">Найдено: <%= products.length %></div>
    </div>
    
    <!-- Фильтры -->
    <form class="filters" method="GET" action="/">
        <select name="category">
            <option value="">Все категории</option>
            <% categories.forEach(c => { %>
                <option value="<%= c %>" <%= c === category ? 'selected' : '' %>><%= c %></option>
            <% }) %>
        </select>
        
        <input name="search" placeholder="Поиск..." value="<%= search %>">
        
        <input name="minPrice" placeholder="Цена от" type="number" value="<%= minPrice || '' %>">
        <input name="maxPrice" placeholder="Цена до" type="number" value="<%= maxPrice || '' %>">
        
        <select name="sort">
            <option value="name" <%= sort === 'name' ? 'selected' : '' %>>По названию</option>
            <option value="price-asc" <%= sort === 'price-asc' ? 'selected' : '' %>>Сначала дешевые</option>
            <option value="price-desc" <%= sort === 'price-desc' ? 'selected' : '' %>>Сначала дорогие</option>
            <option value="rating" <%= sort === 'rating' ? 'selected' : '' %>>По рейтингу</option>
        </select>
        
        <button type="submit">Применить</button>
        <a href="/" class="reset">Сбросить</a>
    </form>
    
    <!-- Список товаров -->
    <div class="grid">
        <% products.forEach(p => { %>
            <div class="card">
                <h3><%= p.name %></h3>
                <div class="category"><%= p.category %></div>
                <div class="rating">⭐ <%= p.rating %></div>
                <div class="price"><%= p.price.toLocaleString() %> ₽</div>
            </div>
        <% }) %>
    </div>
    
    <% if (products.length === 0) { %>
        <p style="text-align:center;margin-top:40px;color:#999;">Товары не найдены</p>
    <% } %>
</body>
</html>