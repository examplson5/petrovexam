<!DOCTYPE html>
<html>
<head><title><%= e.title %></title>
<style>
body { font-family: Arial; max-width: 600px; margin: 50px auto; padding: 20px; }
.back { color: #007bff; text-decoration: none; }
.meta { color: #666; margin: 10px 0; }
.desc { background: #f8f9fa; padding: 15px; border-radius: 8px; margin: 15px 0; }
.guest { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #eee; }
.add { display: flex; gap: 10px; margin: 10px 0; }
.add input { flex: 1; padding: 8px; border: 1px solid #ddd; border-radius: 4px; }
.add button { padding: 8px 20px; background: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; }
.actions a, .actions button { padding: 10px 20px; border-radius: 4px; text-decoration: none; border: none; cursor: pointer; }
.btn-edit { background: #ffc107; color: #333; }
.btn-del { background: #dc3545; color: white; }
.del-guest { background: none; border: none; color: red; cursor: pointer; }
</style>
</head>
<body>
<a href="/" class="back">← Назад</a>
<h1><%= e.title %></h1>
<div class="meta">
  <div>📅 <%= e.date %> <%= e.time ? '🕐 ' + e.time : '' %></div>
  <div>📍 <%= e.location || 'Место не указано' %></div>
</div>
<% if (e.desc) { %><div class="desc"><%= e.desc %></div><% } %>
<h3>👥 Гости (<%= e.guests.length %>)</h3>
<form class="add" method="POST" action="/<%= e.id %>/guest">
  <input name="guest" placeholder="Имя гостя" required><button>➕</button>
</form>
<% e.guests.forEach(g => { %>
<div class="guest"><span><%= g %></span>
  <form method="POST" action="/<%= e.id %>/guest/<%= g %>/delete" style="display:inline;">
    <button class="del-guest" onclick="return confirm('Удалить?')">✕</button>
  </form>
</div>
<% }) %>
<div class="actions" style="margin-top:20px;display:flex;gap:10px;">
  <a href="/<%= e.id %>/edit" class="btn-edit">✏️</a>
  <form method="POST" action="/<%= e.id %>/delete" style="display:inline;">
    <button class="btn-del" onclick="return confirm('Удалить?')">🗑️ Удалить</button>
  </form>
</div>
</body>
</html>