<!DOCTYPE html>
<html>
<head><title>Мероприятия</title>
<style>
body { font-family: Arial; max-width: 800px; margin: 30px auto; padding: 20px; background: #f5f5f5; }
.header { display: flex; justify-content: space-between; align-items: center; }
.btn { padding: 10px 20px; background: #007bff; color: white; text-decoration: none; border-radius: 4px; }
.event { background: white; padding: 15px; border-radius: 8px; margin: 10px 0; display: flex; justify-content: space-between; align-items: center; }
.event .title { font-weight: bold; }
.event .meta { color: #666; font-size: 14px; }
.event .actions a { padding: 5px 10px; border-radius: 4px; text-decoration: none; margin: 0 2px; }
.btn-view { background: #007bff; color: white; }
.btn-edit { background: #ffc107; color: #333; }
.btn-del { background: #dc3545; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; }
.empty { text-align: center; color: #999; padding: 40px; }
</style>
</head>
<body>
<div class="header"><h1>📅 Мероприятия</h1><a href="/new" class="btn">➕ Создать</a></div>
<% if (events.length === 0) { %><div class="empty">Нет мероприятий</div>
<% } else { events.forEach(e => { %>
<div class="event">
  <div><div class="title"><%= e.title %></div><div class="meta">📅 <%= e.date %> <%= e.time ? '🕐 ' + e.time : '' %> 👥 <%= e.guests.length %></div></div>
  <div class="actions">
    <a href="/<%= e.id %>" class="btn-view">👁️</a>
    <a href="/<%= e.id %>/edit" class="btn-edit">✏️</a>
    <form method="POST" action="/<%= e.id %>/delete" style="display:inline;"><button class="btn-del" onclick="return confirm('Удалить?')">🗑️</button></form>
  </div>
</div>
<% }) } %>
</body>
</html>