<!DOCTYPE html>
<html>
<head><title><%= e ? 'Редактировать' : 'Создать' %></title>
<style>
body { font-family: Arial; max-width: 500px; margin: 50px auto; padding: 20px; }
form { display: flex; flex-direction: column; gap: 10px; }
input, textarea { padding: 10px; border: 1px solid #ddd; border-radius: 4px; }
textarea { height: 80px; }
.row { display: flex; gap: 10px; }
.row input { flex: 1; }
button { padding: 12px; background: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; }
.back { color: #007bff; text-decoration: none; }
</style>
</head>
<body>
<a href="/" class="back">← Назад</a>
<h1><%= e ? '✏️ Редактировать' : '➕ Создать' %></h1>
<form method="POST" action="<%= e ? '/' + e.id + '/edit' : '/new' %>">
  <input name="title" placeholder="Название" value="<%= e ? e.title : '' %>" required>
  <textarea name="desc" placeholder="Описание"><%= e ? e.desc : '' %></textarea>
  <div class="row">
    <input name="date" type="date" value="<%= e ? e.date : '' %>" required>
    <input name="time" type="time" value="<%= e ? e.time : '' %>">
  </div>
  <input name="location" placeholder="Место" value="<%= e ? e.location : '' %>">
  <input name="guests" placeholder="Гости (через запятую)" value="<%= e ? e.guests.join(', ') : '' %>">
  <button type="submit"><%= e ? 'Сохранить' : 'Создать' %></button>
</form>
</body>
</html>